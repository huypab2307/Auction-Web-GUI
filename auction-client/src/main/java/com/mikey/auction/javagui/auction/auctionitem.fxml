<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="900.0" prefHeight="720.0" prefWidth="1180.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mikey.auction.javagui.auction.AuctionItemController">
    <stylesheets>
        <URL value="@../style/buttonStyle.css" />
        <URL value="@/com/mikey/auction/javagui/style/menuItem.css" />
    </stylesheets>
    <top>
        <fx:include fx:id="topBar" source="../topbar/topbar.fxml" />
    </top>

    <center>
        <StackPane fx:id="mainStackPane" alignment="TOP_CENTER">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: white;">
                <content>
                    <VBox>
                        <StackPane prefHeight="350.0" style="-fx-background-color: #1c1d1f;">
                            <children>
                                <Pane fx:id="pane" style="-fx-padding: 40 400 40 100; -fx-background-color: linear-gradient(to right, #5cdb95, #05386b);">
                                    <children>
                                        <VBox layoutX="124.0" layoutY="46.0" prefHeight="205.0" prefWidth="830.0" spacing="15.0" style="-fx-padding: 50 0 0 0">
                                            <children>

                                                <Label fx:id="title" style="-fx-font-weight: bold; -fx-font-size: 32; -fx-text-fill: white;" text="Kaguya" textFill="WHITE" wrapText="true" />

                                                <Label fx:id="description" prefHeight="25.0" prefWidth="573.0" style="-fx-font-size: 16; -fx-text-fill: white;" text="Nàng tiên ống tre..." textFill="WHITE" wrapText="true" />

                                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                                    <children>
                                                        <Label style="-fx-text-fill: #ffcc00;" text="⭐ 4.9 (2.5k lượt quan tâm)" />
                                                        <Label fx:id="sellerName" style="-fx-underline: true; -fx-text-fill: #a1d2ff;" text="Người bán: jenny" />
                                                    </children>
                                                </HBox>

                                                <HBox spacing="20.0" style="-fx-padding: 10 0;">
                                                    <children>
                                                        <Label fx:id="startTime" style="-fx-text-fill: white;" text="21/04/2026" />
                                                        <Label fx:id="type" style="-fx-text-fill: white;" text="Loại: ARTS" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <ImageView fitHeight="56.0" fitWidth="56.0" layoutX="688.0" layoutY="39.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@/images/star1.png" /></image></ImageView>
                                        <ImageView fitHeight="27.0" fitWidth="21.0" layoutX="46.0" layoutY="296.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@/images/star1.png" /></image></ImageView>
                                        <ImageView fitHeight="28.0" fitWidth="25.0" layoutX="1129.0" layoutY="216.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@/images/star1.png" /></image></ImageView>
                                        <ImageView fitHeight="30.0" fitWidth="51.0" layoutX="1078.0" layoutY="28.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@/images/star1.png" /></image></ImageView>
                                    </children>
                                </Pane>
                            </children>
                        </StackPane>

                        <AnchorPane style="-fx-padding: 0 100;">
                            <children>
                                <VBox layoutY="40.0" prefWidth="550.0" spacing="30.0" AnchorPane.leftAnchor="0.0">
                                    <children>
                                        <VBox prefHeight="102.0" prefWidth="653.0" spacing="20.0" style="-fx-border-color: #e0e0e0; -fx-padding: 25; -fx-border-width: 1;">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 20;" text="Mô tả vật phẩm" />
                                                <TilePane fx:id="attributeBox" hgap="20.0" vgap="10.0" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 20;" text="Future Feature" />
                                                <Label lineSpacing="5.0" text="All bid transaction will be updated soon!" wrapText="true" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox prefWidth="350.0" spacing="20.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 15, 0, 0, 5); -fx-background-radius: 10; -fx-padding: 2;" translateY="-220.0" AnchorPane.rightAnchor="0.0"> <!-- Nhấc lên vừa đủ để đẹp, không che Top -->
                                    <children>
                                        <ImageView fx:id="image" fitHeight="200.0" fitWidth="346.0" pickOnBounds="true" preserveRatio="false" style="-fx-background-radius: 10 10 0 0;">
                                            <image><Image url="@/images/kaguya.jpg" /></image>
                                        </ImageView>
                                        <VBox spacing="15.0" style="-fx-padding: 20;">
                                            <children>
                                                <HBox alignment="BOTTOM_LEFT" spacing="10.0">
                                                    <children>
                                                        <Label fx:id="curPrice" style="-fx-font-weight: bold; -fx-font-size: 28;" text="15,400,000đ" />
                                                        <Label fx:id="curBidder" style="-fx-text-fill: gray;" text="Khởi điểm: 1,000,000đ" />
                                                    </children>
                                                </HBox>
                                                <Label fx:id="datetime" style="-fx-text-fill: #d32f2f; -fx-font-weight: bold;" text="⏱ Thời gian:" />
                                                <Button fx:id="bidButton" maxWidth="Infinity" onAction="#onBidHandle" prefHeight="50.0" style="-fx-background-color: #2575fc; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16; -fx-background-radius: 5;" text="ĐẶT GIÁ NGAY" />
                                                <Button onAction="#followButton" maxWidth="Infinity" prefHeight="45.0" style="-fx-background-color: transparent; -fx-border-color: #1c1d1f; -fx-border-width: 1; -fx-font-weight: bold;" text="Theo dõi phiên" />
                                                <VBox spacing="10.0" style="-fx-padding: 15 0 0 0;">
                                                    <children>
                                                        <Label style="-fx-font-weight: bold;" text="Thông tin phiên:" />
                                                        <Label fx:id="bidStep" text="• Bước giá tối thiểu: 100,000đ" />
                                                        <Label text="• Phí vận chuyển: Miễn phí" />
                                                        <Label text="• Kiểm định: Đã xác thực" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </AnchorPane>
                    </VBox>
                </content>
            </ScrollPane>
        </StackPane>
    </center>
</BorderPane>
