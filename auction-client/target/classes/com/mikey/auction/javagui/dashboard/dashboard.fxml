<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="953.0" prefWidth="1023.0" spacing="25" style="-fx-padding: 30;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox spacing="30" style="-fx-padding: 30;">
            <Label style="-fx-font-size: 24; -fx-font-weight: bold;" text="tổng quan" textFill="#006af5">
            <font>
               <Font size="22.0" />
            </font></Label>
            <fx:include source="Card/StatCard_TotalSpent.fxml" />
            <FlowPane hgap="20" prefHeight="628.0" prefWidth="806.0" vgap="20">
                <fx:include source="Card/StatCard_ActiveBids.fxml" />
                <fx:include source="Card/StatCard_Wins.fxml" />
                <fx:include source="Card/StatCard_WinRate.fxml" />

                <fx:include source="Card/StatCard_Outbid.fxml" />
                <fx:include source="Card/StatCard_Watchlist.fxml" />
                <fx:include source="Card/StatCard_Sold.fxml" />
            </FlowPane>
            <VBox spacing="15" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Hoạt động gần đây" />
                <VBox fx:id="activityList" spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" />
            </VBox>
        </VBox>
    </HBox>
</VBox>
