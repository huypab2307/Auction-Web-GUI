<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mikey.auction.javagui.dashboard.GeneralController">
    <stylesheets>
        <URL value="@../style/buttonStyle.css" />
        <URL value="@/com/mikey/auction/javagui/style/menuItem.css" />
    </stylesheets>
    <fx:define>
        <ToggleGroup fx:id="categoryGroup" />
    </fx:define>
    <top>
        <fx:include fx:id="topBar" source="../topbar/topbar.fxml" />
    </top>

    <left>
        <VBox prefHeight="730.0" prefWidth="207.0" spacing="20" style="-fx-background-color: #ffffff; -fx-padding: 20;">
            <ToggleButton fx:id="genaralButton" onAction="#generalButton" maxWidth="Infinity" styleClass="buttonStyle" text="Tổng quan" toggleGroup="$categoryGroup" selected="true" />
            <ToggleButton fx:id="myAuctionButton" onAction="#myAuctionButton" maxWidth="Infinity" styleClass="buttonStyle" text="Phiên đấu giá của tôi" toggleGroup="$categoryGroup" />
            <ToggleButton fx:id="userConfigButton" maxWidth="Infinity" styleClass="buttonStyle" text="Tài khoản" toggleGroup="$categoryGroup" />
        </VBox>
    </left>

    <center>
        <ScrollPane fx:id="mainContainer" fitToWidth="true" style="-fx-background-color: transparent;" >
        </ScrollPane>
    </center>
</BorderPane>