<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mikey.auction.javagui.login.RegisterController">
<AnchorPane prefHeight="800.0" prefWidth="508.0" style="-fx-background-color: white" BorderPane.alignment="CENTER">
