<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="640.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label alignment="CENTER" prefWidth="626.0" styleClass="section-title" text="Thông tin chi tiết" />
      <GridPane alignment="TOP_CENTER" hgap="20.0" prefWidth="619.0" vgap="20.0">
         <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
         </columnConstraints>
         <rowConstraints>
            <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
         </rowConstraints>
         <children>
            <VBox spacing="5" styleClass="input-group">
               <children>
                  <Label styleClass="field-label" text="Số km đã đi:" />
                  <TextField fx:id="mileage" prefHeight="35.0" promptText="Nhập số km đã đi" styleClass="input-field" />
               </children>
            </VBox>
            <VBox spacing="5" styleClass="input-group" GridPane.columnIndex="1">
               <children>
                  <Label styleClass="field-label" text="Ngày sản xuất:" />
                  <TextField fx:id="mFG" prefHeight="35.0" promptText="Nhập ngày sản xuất" styleClass="input-field" />
               </children>
            </VBox>
            <VBox spacing="5" styleClass="input-group" GridPane.rowIndex="1">
               <children>
                  <Label styleClass="field-label" text="Thương hiệu:" />
                  <TextField fx:id="brand" prefHeight="35.0" promptText="Nhập thương hiệu" styleClass="input-field" />
               </children>
            </VBox>
            <VBox spacing="5" styleClass="input-group" GridPane.columnIndex="1" GridPane.rowIndex="1">
               <children>
                  <Label styleClass="field-label" text="Dòng xe:" />
                  <TextField fx:id="model" prefHeight="35.0" promptText="Nhập dòng xe" styleClass="input-field" />
               </children>
            </VBox>
            <VBox spacing="5" styleClass="input-group" GridPane.rowIndex="2">
               <children>
                  <Label styleClass="field-label" text="Phiên bản:" />
                  <TextField fx:id="trim" prefHeight="35.0" promptText="Nhập phiên bản" styleClass="input-field" />
               </children>
            </VBox>
            <VBox spacing="5" styleClass="input-group" GridPane.columnIndex="1" GridPane.rowIndex="2">
               <children>
                  <Label styleClass="field-label" text="Tình trạng giấy tờ:" />
                  <TextField fx:id="titleStatus" prefHeight="35.0" promptText="Nhập tình trạng giấy tờ" styleClass="input-field" />
               </children>
            </VBox>
         </children>
         <VBox.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </VBox.margin>
      </GridPane>
   </children>
</VBox>
