<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="400.0" spacing="15.0" style="-fx-background-color: #f4f7f6; -fx-padding: 30;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="JavaGui.RegisterController">
   <children>
      <Label text="ĐĂNG KÝ TÀI KHOẢN" textFill="#2c3e50">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      
      <VBox maxWidth="300.0" spacing="8.0">
         <children>
            <Label text="Tên đăng nhập:" textFill="#34495e">
               <font><Font name="System Bold" size="13.0" /></font>
               <VBox.margin><Insets top="5.0" /></VBox.margin>
            </Label>
            <TextField fx:id="regUserField" promptText="Nhập tên đăng nhập..." style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" />
            
            <Label text="Mật khẩu:" textFill="#34495e">
               <font><Font name="System Bold" size="13.0" /></font>
               <VBox.margin><Insets top="5.0" /></VBox.margin>
            </Label>
            <PasswordField fx:id="regPassField" promptText="Nhập mật khẩu..." style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" />

            <Label text="Nhập lại mật khẩu:" textFill="#34495e">
               <font><Font name="System Bold" size="13.0" /></font>
               <VBox.margin><Insets top="5.0" /></VBox.margin>
            </Label>
            <PasswordField fx:id="regConfirmPassField" promptText="Xác nhận lại mật khẩu..." style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" />
         </children>
      </VBox>

      <Label fx:id="regMessageLabel" text="" />

      <Button mnemonicParsing="false" onAction="#handleRegister" prefHeight="40.0" prefWidth="300.0" style="-fx-background-color: blue; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="TẠO TÀI KHOẢN">
         <VBox.margin><Insets top="10.0" /></VBox.margin>
      </Button>

      <Hyperlink onAction="#switchToLogin" text="Đã có tài khoản? Đăng nhập ngay" textFill="#2980b9" />
   </children>
</VBox>
