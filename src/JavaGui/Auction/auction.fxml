<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="600.0" minWidth="900.0" prefHeight="720.0" prefWidth="1180.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="JavaGui.Auction.AuctionController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 2);">
            <children>
                <Label text="COSMIC" textFill="#2575fc">
                    <font><Font name="System Bold" size="24.0" /></font>
                    <HBox.margin><Insets left="20.0" /></HBox.margin>
                </Label>

                <HBox alignment="CENTER_LEFT" maxHeight="40.0" prefHeight="40.0" style="-fx-background-color: #f1f3f4; -fx-background-radius: 20; -fx-padding: 0 15;" HBox.hgrow="ALWAYS">
                    <children>
                        <TextField promptText="Tìm kiếm phiên đấu giá..." style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS" />
                    </children>
                    <HBox.margin><Insets left="50.0" right="50.0" /></HBox.margin>
                </HBox>

                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button style="-fx-background-color: transparent;" text="🔔" />
                        <MenuButton mnemonicParsing="false" style="-fx-background-color: transparent;">
                            <graphic>
                                <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true" style="-fx-background-size: cover;-fx-background-position: center;-fx-background-radius: 10;">
                                    <image>
                                        <Image url="@../../images/earth.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                            <items>
                                <MenuItem mnemonicParsing="false" text="👤 Thông tin cá nhân" />
                                <MenuItem mnemonicParsing="false" text="👤 Đến trang người bán" />
                                <MenuItem mnemonicParsing="false" text="👤 lịch sử giao dịch" />
                                <MenuItem mnemonicParsing="false" text="⚙️ Cài đặt" />
                                <SeparatorMenuItem mnemonicParsing="false" />
                                <MenuItem mnemonicParsing="false" text="🚪 Đăng xuất" />
                            </items>
                        </MenuButton>
                    </children>
                    <HBox.margin><Insets right="20.0" /></HBox.margin>
                </HBox>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="10.0" style="-fx-background-color: #fafafa; -fx-border-color: #eeeeee; -fx-border-width: 0 1 0 0;">
            <children>
                <Label text="DANH MỤC" textFill="GRAY">
                    <font><Font name="System Bold" size="12.0" /></font>
                    <VBox.margin><Insets bottom="10.0" top="20.0" /></VBox.margin>
                </Label>
                <ToggleButton maxWidth="Infinity" selected="true" style="-fx-background-color: #e3f2fd; -fx-text-fill: #1976d2; -fx-alignment: CENTER_LEFT;" text="🌐 tất cả" />
                <ToggleButton maxWidth="Infinity" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT;" text="🎨 Art" />
                <ToggleButton maxWidth="Infinity" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT;" text="📈 Kinh doanh" />
                <ToggleButton maxWidth="Infinity" style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT;" text="🎵 Âm nhạc" />
            </children>
            <padding><Insets left="15.0" right="15.0" /></padding>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="30.0" style="-fx-padding: 30;">
                    <children>

                        <StackPane prefHeight="200.0" style="-fx-background-color: linear-gradient(to right, #6a11cb, #2575fc); -fx-background-radius: 20;">
                            <children>
                                <VBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Đấu giá không giới hạn" textFill="WHITE">
                                            <font><Font name="System Bold" size="30.0" /></font>
                                        </Label>
                                        <Label text="các phiên đấu giá hàng đầu" textFill="WHITE" />
                                        <Button prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: white; -fx-text-fill: #2575fc; -fx-background-radius: 10; -fx-font-weight: bold;" text="Khám phá ngay" />
                                    </children>
                                    <padding><Insets left="40.0" /></padding>
                                </VBox>
                            </children>
                        </StackPane>

                        <VBox spacing="15.0">
                            <children>
                                <HBox alignment="BOTTOM_LEFT">
                                    <children>
                                        <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="Tất cả" />
                                    </children>
                                </HBox>

                                <FlowPane fx:id="mainContainer" hgap="20.0" vgap="20.0">
                                    <children>

                                    </children>
                                </FlowPane>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
