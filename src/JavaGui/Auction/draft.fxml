                                            <Label style="-fx-text-fill: #d32f2f; -fx-font-weight: bold;" text="⏱ Thời gian còn lại: 02:45:10" />

                                            <Button maxWidth="Infinity" prefHeight="50.0" style="-fx-background-color: #2575fc; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16; -fx-background-radius: 5;" text="ĐẶT GIÁ NGAY" />
                                            <Button maxWidth="Infinity" prefHeight="45.0" style="-fx-background-color: transparent; -fx-border-color: #1c1d1f; -fx-border-width: 1; -fx-font-weight: bold;" text="Theo dõi phiên" />

