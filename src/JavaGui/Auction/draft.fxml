                                                    <Label text="• Phí vận chuyển: Miễn phí" />
                                                    <Label text="• Kiểm định: Đã xác thực" />
                                                </children>
                                            </VBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
