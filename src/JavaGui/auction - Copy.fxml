<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="JavaGui.AuctionController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 0 20;">
         <children>
            <Label text="SÀN ĐẤU GIÁ" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            
            <TextField promptText="Tìm kiếm sản phẩm..." style="-fx-background-radius: 20; -fx-padding: 5 15;" HBox.hgrow="ALWAYS" />
            
            <Button mnemonicParsing="false" onAction="#showNotifications" style="-fx-background-color: #f1c40f; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 15; -fx-padding: 5 15;" text="🔔 Thông báo" />

            <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Đăng xuất" />
         </children>
      </HBox>

      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
         <content>
            <VBox fx:id="itemContainer" spacing="20.0" style="-fx-padding: 20;">
               <children>
                  <HBox spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                     <children>
                        <VBox prefHeight="100.0" prefWidth="120.0" style="-fx-background-color: #bdc3c7; -fx-background-radius: 5;" />
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Laptop MacBook Pro M3 Max" textFill="#2c3e50">
                                 <font><Font name="System Bold" size="18.0" /></font>
                              </Label>
                              <Label text="Người đang giữ giá: Ngô Gia Huy" textFill="#7f8c8d" />
                              <HBox spacing="30.0">
                                 <children>
                                    <Label text="Giá hiện tại: 45.000.000đ" textFill="#e67e22">
                                       <font><Font name="System Bold" size="16.0" /></font>
                                    </Label>
                                    <Label text="Thời gian còn lại: 02:45:10" textFill="#c0392b" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        <Button mnemonicParsing="false" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="ĐẶT GIÁ" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</VBox>