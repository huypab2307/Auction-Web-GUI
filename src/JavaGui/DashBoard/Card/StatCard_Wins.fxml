<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="220" prefHeight="120" spacing="10"
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; 
             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">

    <Label text="Sản phẩm đã thắng" style="-fx-font-size: 14; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" />

    <Label fx:id="winsValue" text="12"
           style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #28C76F;" />

    <Label text="Vừa thắng 1 món đồ cổ" style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;" />
</VBox>