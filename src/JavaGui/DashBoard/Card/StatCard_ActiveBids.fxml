<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="320" prefHeight="120" spacing="10"
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;
             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">

    <Label text="Đang đấu giá" style="-fx-font-size: 14; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" />

    <Label fx:id="activeBidsValue" text="08"
           style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #FF9F43;" />

    <Label text="3 phiên sắp kết thúc" style="-fx-font-size: 11; -fx-text-fill: #e67e22;" />
</VBox>