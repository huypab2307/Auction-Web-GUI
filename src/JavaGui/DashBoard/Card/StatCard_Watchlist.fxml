<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<VBox prefWidth="320" prefHeight="110" spacing="10" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
    <Label text="Đang theo dõi" style="-fx-font-size: 14; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" />
    <Label fx:id="watchCount" text="15" style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #F1C40F;" />
    <Label text="Vật phẩm quan tâm" style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;" />
</VBox>