<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<SplitPane dividerPositions="0.35" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="JavaGui.ChatController">
    <items>
        <VBox style="-fx-background-color: #f8f9fa;">
            <VBox style="-fx-padding: 15; -fx-background-color: #ffffff; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;">
                <Label text="💬 Nhắn tin" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                <HBox spacing="10" style="-fx-padding: 15 0 0 0;">
                    <TextField fx:id="searchUserField" promptText="Nhập tên tài khoản..." HBox.hgrow="ALWAYS" style="-fx-background-radius: 15; -fx-padding: 8 12;"/>
                    <Button text="Tìm" onAction="#handleSearchUser" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 15; -fx-cursor: hand; -fx-padding: 8 15;"/>
                </HBox>
            </VBox>
            
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox fx:id="userListContainer" spacing="5" style="-fx-padding: 10;">
                    </VBox>
            </ScrollPane>
        </VBox>

        <VBox style="-fx-background-color: #ffffff;">
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0; -fx-background-color: #f8f9fa;">
                <Label fx:id="chatUserNameLabel" text="Hãy chọn một đoạn chat..." style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            </HBox>

            <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: #ffffff; -fx-background-color: #ffffff;">
                <VBox fx:id="chatHistoryBox" spacing="15" style="-fx-padding: 20;">
                    </VBox>
            </ScrollPane>

            <HBox spacing="15" alignment="CENTER" style="-fx-padding: 15; -fx-border-color: #dee2e6; -fx-border-width: 1 0 0 0; -fx-background-color: #f8f9fa;">
                <TextField fx:id="messageInput" promptText="Nhập tin nhắn..." HBox.hgrow="ALWAYS" style="-fx-padding: 12; -fx-background-radius: 20;" onAction="#handleSendMessage"/>
                <Button text="Gửi 🚀" onAction="#handleSendMessage" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 20; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </items>
</SplitPane>