        "libs/javafx-sdk-21.0.10/lib/javafx.base.jar",
        "libs/javafx-sdk-21.0.10/lib/javafx.controls.jar",
        "libs/javafx-sdk-21.0.10/lib/javafx.fxml.jar",
        "libs/javafx-sdk-21.0.10/lib/javafx.graphics.jar",
        "libs/javafx-sdk-21.0.10/lib/javafx.media.jar",
        "libs/javafx-sdk-21.0.10/lib/javafx.swing.jar",
        "libs/javafx-sdk-21.0.10/lib/javafx.web.jar",
        "libs/javafx-sdk-21.0.10/lib/javafx-swt.jar"
    ],
    "files.encoding": "utf8",
    "java.debug.settings.vmArgs": "-Dfile.encoding=UTF-8",
    "java.jdt.ls.vmargs": "-Dfile.encoding=UTF-8",

    "terminal.integrated.profiles.windows": {
        "PowerShell UTF-8": {
            "source": "PowerShell",
